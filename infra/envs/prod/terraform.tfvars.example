# infra/envs/prod/terraform.tfvars.example
# Copy to terraform.tfvars and fill in values

aws_region   = "us-west-1"
environment  = "prod"
project_name = "zoom-etl"

vpc_cidr             = "10.50.0.0/16"
availability_zones   = ["us-west-1a", "us-west-1b"]
public_subnet_cidrs  = ["10.50.1.0/24", "10.50.2.0/24"]
private_subnet_cidrs = ["10.50.10.0/24", "10.50.11.0/24"]

db_password     = "" # Use a strong password, URL-safe characters only
db_instance_class = "db.t4g.micro"

redis_node_type = "cache.t4g.micro"

airflow_webserver_cpu    = 1024
airflow_webserver_memory = 2048
airflow_scheduler_cpu    = 1024
airflow_scheduler_memory = 2048
airflow_worker_cpu       = 2048
airflow_worker_memory    = 8192
airflow_triggerer_cpu    = 512
airflow_triggerer_memory = 1024

worker_desired_count = 1
